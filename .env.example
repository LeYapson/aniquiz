# Base de données
DATABASE_URL=postgres://postgres@localhost:5432/postgres?sslmode=disable

# JWT (générer avec : openssl rand -hex 32)
JWT_SECRET=change_me_in_production

# URL du frontend (pour CORS et redirects OAuth)
FRONTEND_URL=http://localhost:5173

# Port du serveur (optionnel, défaut 8080)
# PORT=8080

# AniList OAuth (https://anilist.co/settings/developer)
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=
ANILIST_REDIRECT_URI=http://localhost:8080/api/auth/anilist/callback

# MyAnimeList OAuth (https://myanimelist.net/apiconfig)
MAL_CLIENT_ID=
MAL_CLIENT_SECRET=
MAL_REDIRECT_URI=http://localhost:8080/api/auth/mal/callback


POSTGRES_USER=aniquiz
POSTGRES_PASSWORD=change_me      # required by prod compose
POSTGRES_DB=aniquiz
IMAGE_TAG=latest
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me        # required by monitoring compose
GRAFANA_URL=http://localhost:3000

